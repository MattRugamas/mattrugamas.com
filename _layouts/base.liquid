<!doctype html>
<html lang="en">

  <head>
    <script>
      (function () {
        var t = localStorage.getItem('theme');
        if (t) {
          document.documentElement.setAttribute('data-theme', t);
          var c = t === 'dark' ? '#2A2D33' : '#F8F5EE';
          var m = document.querySelectorAll('meta[name="theme-color"]');
          for (var i = 0; i < m.length; i++) m[i].setAttribute('content', c);
        }
      })();
    </script>
    {% if site.google_analytics and jekyll.environment == 'production' %}
      <!-- Global site tag (gtag.js) - Google Analytics -->
      <script async src="https://www.googletagmanager.com/gtag/js?id=G-EC57RQ9MNY"></script>
      <script src="/assets/js/ga-bootstrap.js"></script>
    {% endif %}
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin>
    <link rel="stylesheet" href="/assets/css/styles.css" />
    <link
      rel="preload"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Source+Code+Pro:wght@400&display=swap"
      as="style"
      onload="this.onload=null;this.rel='stylesheet'">
    <noscript>
      <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Source+Code+Pro:wght@400&display=swap" rel="stylesheet">
    </noscript>
    {% include faviconpackage.html %}
    {% feed_meta %}
    {% seo %}
  </head>

  <body>
    {% if page.layout == 'minimal' %}
      {% include minimal-chrome.html %}
    {% else %}
      {% include navigation.html %}
    {% endif %}
    {{ content }}
    {% unless page.layout == 'minimal' %}
    <footer>
      <p>2019-{{ 'now' | date: '%Y' }} — Made with ❤️ on
        <strong>
          <a href="https://www.jekyllrb.com">Jekyll</a>
        </strong>
        and
        <strong>
          <a href="https://pages.github.com">GitHub Pages</a>
        </strong>.</p>
    </footer>
    {% endunless %}
    <script src="/assets/js/site.js" defer></script>
    <script src="/assets/js/analytics.js" defer></script>
  </body>

</html>