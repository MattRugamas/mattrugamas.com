---
layout: base
---
<main id="mainContent" tabindex="-1">
  <h1 class="hello">Posts tagged
    <strong>{{ page.tag }}</strong>
  </h1>
  {% include tag-filter.html %}
  {% assign tagged_posts = site.tags[page.tag] %}
  {% assign posts_by_year = tagged_posts | group_by_exp: "post", "post.date | date: '%Y'" %}
  <ul id="blog-list">
    {% for year_group in posts_by_year %}
      <li class="year-group">
        <h2 class="year-heading">{{ year_group.name }}</h2>
        <ul class="year-posts">
          {% for post in year_group.items %}
            <li>
              <article>
                <aside>
                  <time class="date" datetime="{{ post.date | date_to_xmlschema }}">{{ post.date | date: "%b %d" }}</time>
                </aside>
                <header>
                  {% if post.tags.size > 0 %}
                    <div class="post-tags">
                      {% for tag in post.tags %}
                        <a href="/tags/{{ tag }}/" class="tag-badge">{{ tag | capitalize }}</a>
                      {% endfor %}
                    </div>
                  {% endif %}
                  <h3>
                    <a href="{{ post.url }}">{{ post.title }}</a>
                  </h3>
                  {{ post.excerpt }}
                </header>
              </article>
            </li>
          {% endfor %}
        </ul>
      </li>
    {% endfor %}
  </ul>
</main>