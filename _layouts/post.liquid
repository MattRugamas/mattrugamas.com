---
layout: base
---
{% assign other_posts = site.posts | where_exp: "post", "post.url != page.url" %}
{% assign random_fallback = other_posts | first %}
<main id="mainContent" tabindex="-1">
  <article class="blogpost">
    <h1 id="post-title">{{ page.title }}</h1>
    <time id="post-date" datetime="{{ page.date | date_to_xmlschema }}">{{ page.date | date: "%B %-d, %Y" }}</time>
    {% if page.tags.size > 0 %}
      <div class="post-tags">
        {% for tag in page.tags %}
          <a href="/tags/{{ tag }}/" class="tag-badge">{{ tag | capitalize }}</a>
        {% endfor %}
      </div>
    {% endif %}
    {{ content }}
  </article>
  <section class="post-comments" aria-label="Comments">
    <script>
      (function() {
        var stored = localStorage.getItem('theme');
        var isDark = stored ? stored === 'dark' : window.matchMedia('(prefers-color-scheme: dark)').matches;
        var s = document.createElement('script');
        s.src = 'https://giscus.app/client.js';
        s.setAttribute('data-repo', 'mattrugamas/mattrugamas.com');
        s.setAttribute('data-repo-id', 'MDEwOlJlcG9zaXRvcnkxNjA2NDAzNjU=');
        s.setAttribute('data-category', 'Announcements');
        s.setAttribute('data-category-id', 'DIC_kwDOCZMtbc4C6mWJ');
        s.setAttribute('data-mapping', 'pathname');
        s.setAttribute('data-strict', '0');
        s.setAttribute('data-reactions-enabled', '1');
        s.setAttribute('data-emit-metadata', '0');
        s.setAttribute('data-input-position', 'top');
        s.setAttribute('data-theme', isDark ? 'dark' : 'light');
        s.setAttribute('data-lang', 'en');
        s.setAttribute('crossorigin', 'anonymous');
        s.async = true;
        document.currentScript.parentNode.appendChild(s);
      })();
    </script>
  </section>
  <section class="post-footer">
    <nav aria-label="Adjacent and random posts">
      <dl class="post-footer-nav">
        <div class="post-footer-row">
          <dt>Next</dt>
          <dd>
            {% if page.next %}
              <a href="{{ page.next.url }}">{{ page.next.title }}</a>
            {% else %}
              <em>No newer post</em>
            {% endif %}
          </dd>
        </div>
        <div class="post-footer-row">
          <dt>Previous</dt>
          <dd>
            {% if page.previous %}
              <a href="{{ page.previous.url }}">{{ page.previous.title }}</a>
            {% else %}
              <em>No older post</em>
            {% endif %}
          </dd>
        </div>
        <div class="post-footer-row">
          <dt>Random</dt>
          <dd>
            {% if random_fallback %}
              <a href="{{ random_fallback.url }}" id="random-post">{{ random_fallback.title | escape }}</a>
            {% else %}
              <em>No other post</em>
            {% endif %}
          </dd>
        </div>
      </dl>
    </nav>
    <ol class="post-footer-elsewhere">
      <li>
        <a href="/feed.xml">Subscribe via RSS</a>
      </li>
      <li>
        <a href="/about">Get to know me</a>
      </li>
      <li>{% include obfuscated-email.html text="Reply via email" %}</li>
    </ol>
  </section>
  <script>
    (function() {
      var posts = [
        {% for post in site.posts %}
          { url: "{{ post.url }}", title: "{{ post.title | escape }}" }{% unless forloop.last %},{% endunless %}
        {% endfor %}
      ];
      var link = document.getElementById('random-post');
      if (link && posts.length > 1) {
        var others = posts.filter(function(p) { return p.url !== "{{ page.url }}"; });
        var pick = others[Math.floor(Math.random() * others.length)];
        link.href = pick.url;
        link.textContent = pick.title;
      }
    })();
  </script>
</main>
